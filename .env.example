# ──────────────────────────────────────────────────────────────────
# DocIQ Environment Variables
# ──────────────────────────────────────────────────────────────────
# Copy this file to `.env` in the project root and fill in values.
# Every variable is prefixed with DOCIQ_ and maps to a setting in
# src/config.py.  Environment variables override config.yaml values.
# ──────────────────────────────────────────────────────────────────

# ── Secrets / External Paths ─────────────────────────────────────
# Path to the Tesseract OCR binary (if not on PATH)
# DOCIQ_TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# Path to the Poppler bin directory (for pdf2image on Windows)
# DOCIQ_POPPLER_PATH=C:/tools/poppler/Library/bin

# ── General ───────────────────────────────────────────────────────
# DOCIQ_LOG_LEVEL=INFO
# DOCIQ_VERSION=1.0.0

# ── Paths ─────────────────────────────────────────────────────────
# DOCIQ_INPUT_DIR=data/generated
# DOCIQ_OUTPUT_DIR=output
# DOCIQ_TEMP_DIR=/tmp/dociq

# ── Pipeline ──────────────────────────────────────────────────────
# DOCIQ_OCR_DPI=300
# DOCIQ_OCR_LANG=eng+spa
# DOCIQ_RUN_INFERENCE=true
# DOCIQ_MAX_WORKERS=4

# ── API Server ────────────────────────────────────────────────────
# DOCIQ_API_HOST=0.0.0.0
# DOCIQ_API_PORT=8000
# DOCIQ_API_WORKERS=1
# DOCIQ_API_RELOAD=false
